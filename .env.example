# =============================================================================
# Stock Analysis Agent — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# AWS Credentials (required for Bedrock LLM)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# Bedrock LLM
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0
AGENT_TEMPERATURE=0.2
AGENT_TOP_P=0.9
AGENT_MAX_TOKENS=8192

# Stock Analysis
DEFAULT_EXCHANGE=NSE
STOCKS_FILE=stocks.txt
NEWS_SEARCH_COUNT=100
HISTORICAL_DAYS=365
DMA_PERIOD=200

# Rate Limiting
SCRAPE_DELAY_SECONDS=1.0
NEWS_API_DELAY=0.5

# Session
SESSION_BACKEND=file
SESSION_DIR=.sessions

# Report Database & PDF Export
REPORT_CACHE_HOURS=720      # 30 days default. 0 = never expire cached reports
REPORTS_DIR=reports         # directory for auto-saved PDF files
DB_PATH=data/reports.db     # SQLite database path
